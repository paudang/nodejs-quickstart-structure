  Query: {
    getAllUsers: async (_: unknown, __: unknown, <% if (auth.includes('JWT')) { %>context<% } else { %>_context<% } %>: MyContext) => {
      <%_ if (auth.includes('JWT')) { -%>
      if (!context.user) throw new Error('Unauthorized');
      <%_ } -%>
      const users = await userController.getUsers();
      return users;
    }
