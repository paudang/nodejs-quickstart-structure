const userController = require('../../controllers/userController');

const userResolvers = {
  Query: {
    getAllUsers: async () => {
      return await userController.getUsers();
    }
  },
  Mutation: {
    createUser: async (_, { name, email }) => {
      return await userController.createUser({ name, email });
    }
  }
};

module.exports = { userResolvers };
