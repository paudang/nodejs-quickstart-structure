      expect(result).toBe('123');
    });

    it('should fallback to parent._id if id is not available', () => {
      const parent = { _id: '456' };
      const result = userResolvers.User.id(parent);
      expect(result).toBe('456');
    });
  });
<%_ } -%>
});
