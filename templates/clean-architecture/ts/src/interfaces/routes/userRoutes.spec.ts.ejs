import request from 'supertest';
import express, { Express } from 'express';
import router from '@/interfaces/routes/userRoutes';
import { UserController } from '@/interfaces/controllers/userController';

jest.mock('@/interfaces/controllers/userController');

describe('UserRoutes', () => {
    let app: Express;
    let mockController: jest.Mocked<UserController>;

    beforeEach(() => {
        app = express();
        app.use(express.json());
        app.use('/users', router);

        // Get the mock instance
        mockController = (UserController as jest.Mock).mock.instances[0] as jest.Mocked<UserController>;
    });

    it('POST /users should call controller.createUser', async () => {
        await request(app)
            .post('/users')
            .send({ name: 'Test', email: 'test@example.com' });

        expect(mockController.createUser).toHaveBeenCalled();
    });

    it('GET /users should call controller.getUsers', async () => {
        await request(app)
            .get('/users');

        expect(mockController.getUsers).toHaveBeenCalled();
    });
});
