import dotenv from 'dotenv';
import { z } from 'zod';
import logger from '@/infrastructure/log/logger';

if (process.env.NODE_ENV !== 'production') {
  dotenv.config();
}

const envSchema = z.object({
  NODE_ENV: z.enum(['development', 'production', 'test']).default('development'),
  PORT: z.string().transform(Number).default('3000'),
<%_ if (database !== 'None') { -%>
  DB_HOST: z.string(),
<%_ if (database === 'MySQL') { -%>
  DB_USER: z.string(),
  DB_PASSWORD: z.string(),
  DB_NAME: z.string(),
  DB_PORT: z.string().transform(Number),
<%_ } else if (database === 'PostgreSQL') { -%>
  DB_USER: z.string(),
  DB_PASSWORD: z.string(),
  DB_NAME: z.string(),
  DB_PORT: z.string().transform(Number),
<%_ } else if (database === 'MongoDB') { -%>
  DB_NAME: z.string(),
  DB_PORT: z.string().transform(Number),
<%_ } -%>
<%_ } -%>
<%_ if (caching === 'Redis') { -%>
  REDIS_HOST: z.string(),
  REDIS_PORT: z.string().transform(Number),
  REDIS_PASSWORD: z.string().optional(),
<%_ } -%>
<%_ if (communication === 'Kafka') { -%>
  KAFKA_BROKER: z.string(),
<%_ } -%>
<%_ if (auth.includes('JWT')) { _%>
  JWT_SECRET: z.string(),
  JWT_EXPIRES_IN: z.string().default('15m'),
  JWT_REFRESH_SECRET: z.string().default('your-secret-refresh-key'),
  JWT_REFRESH_EXPIRES_IN: z.string().default('7d'),
<%_ if (socialAuth && socialAuth.includes('Google')) { _%>
  GOOGLE_CLIENT_ID: z.string(),
  GOOGLE_CLIENT_SECRET: z.string(),
  GOOGLE_CALLBACK_URL: z.string().optional(),
<%_ } _%>
<%_ if (socialAuth && socialAuth.includes('GitHub')) { _%>
  GITHUB_CLIENT_ID: z.string(),
  GITHUB_CLIENT_SECRET: z.string(),
  GITHUB_CALLBACK_URL: z.string().optional(),
<%_ } _%>
<%_ } _%>
});

const _env = envSchema.safeParse(process.env);

if (!_env.success) {
  if (process.env.NODE_ENV !== 'test') {
    logger.error('❌ Invalid environment variables:', _env.error.format());
    process.exit(1);
  }
  logger.warn('⚠️ Environment validation failed. Continuing in test mode.');
}

export const env = (_env.success ? _env.data : process.env) as unknown as z.infer<typeof envSchema>;
