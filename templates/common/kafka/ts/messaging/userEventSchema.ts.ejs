import { z } from 'zod';

export const UserEventSchema = z.object({
  action: z.enum(['USER_CREATED', 'USER_UPDATED', 'USER_DELETED']),
  payload: z.object({
    id: z.union([z.string(), z.number()]),
    email: z.string().email().optional(),
  }),
});

export type UserEvent = z.infer<typeof UserEventSchema>;
