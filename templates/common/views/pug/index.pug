doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title= projectName
    link(rel="stylesheet", href="/css/style.css")
  body
    .container
      header.header
        .logo 🚀
        h1 Welcome to #{projectName}
        p.subtitle A production-ready Node.js microservice starter.

      if auth && auth.includes('JWT')
        .auth-bar(style="text-align: right; margin-bottom: 20px;")
          a.btn-link(href="/login") Login
          |  | 
          a.btn-link(href="/signup") Sign Up


      .card-grid
        .card
          h3 Architecture
          p #{architecture}
        .card
          h3 Database
          p #{database}
        .card
          h3 Communication
          p #{communication}

      if communication === 'Kafka'
        .status-card
          .status-icon 🔄
          .status-content
            h3 Kafka Connected
            p Connection to broker established successfully.
      else 
        .status-card
          .status-icon ✅
          .status-content
            h3 API Active
            p REST API is running and ready to accept requests.

      footer
        p Generated with ❤️ by Node.js Quickstart Generator
