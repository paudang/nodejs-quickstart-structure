  });

  afterAll(async () => {
    // Wait slightly to let Kafka events finish before killing connection
    await new Promise(resolve => setTimeout(resolve, 500));
    
    <%_ if (database === 'MySQL' || database === 'PostgreSQL') { _%>
    if (sequelize && sequelize.close) await sequelize.close();
    <%_ } _%>
    <%_ if (database === 'MongoDB') { _%>
    if (mongoose.connection && mongoose.connection.readyState !== 0) {
        await mongoose.disconnect();
    }
    <%_ } _%>
  });

  it('should create a user and verify flow', async () => {
    <%_ if (communication === 'GraphQL') { _%>
