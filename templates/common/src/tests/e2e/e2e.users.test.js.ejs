const SERVER_URL = process.env.TEST_URL || `http://127.0.0.1:${process.env.PORT || 3000}`;

describe('E2E User Tests', () => {
  beforeAll(async () => {
    // Basic setup depending on the app entrypoint.
    <%_ if (database === 'MySQL' || database === 'PostgreSQL') { _%>
    if (sequelize && sequelize.sync) {
