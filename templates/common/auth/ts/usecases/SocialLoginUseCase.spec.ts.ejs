describe('SocialLoginUseCase', () => {
  let useCase: SocialLoginUseCase;
  let mockProvider: any;
  <%_ if (architecture === 'Clean Architecture') { _%>
  let mockRepo: any;
  <%_ } _%>

  beforeEach(() => {
    mockProvider = {
