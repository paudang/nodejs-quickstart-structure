const bcrypt = require('bcryptjs');
<%_ if (architecture === 'Clean Architecture') { _%>
const { AuthController } = require('../../../src/interfaces/controllers/auth/authController');
const { JwtService } = require('../../../src/infrastructure/auth/jwtService');
<%_ } else { _%>
const { AuthController } = require('../../../src/controllers/authController');
const { JwtService } = require('../../../src/services/jwtService');
<%_ } _%>
const { HTTP_STATUS } = require('../../../src/utils/httpCodes');

jest.mock('bcryptjs');
<%_ if (architecture === 'Clean Architecture') { _%>
jest.mock('../../../src/infrastructure/auth/jwtService');
jest.mock('../../../src/infrastructure/database/models/User', () => ({
    findOne: jest.fn()
}));
const User = require('../../../src/infrastructure/database/models/User');
<%_ } else { _%>
jest.mock('../../../src/services/jwtService');
jest.mock('../../../src/models/User', () => ({
    findOne: jest.fn()
}));
const User = require('../../../src/models/User');
<%_ } _%>

describe('AuthController', () => {
    let authController;
    let mockReq;
    let mockRes;
    let next;

    beforeEach(() => {
        authController = new AuthController();
        mockReq = {
            body: {}
        };
        mockRes = {
            status: jest.fn().mockReturnThis(),
            json: jest.fn()
        };
        next = jest.fn();
        jest.clearAllMocks();
    });

    describe('login', () => {
        it('should return token on success', async () => {
            const user = { email: 'test@test.com', password: 'hashedpassword' };
            mockReq.body = { email: 'test@test.com', password: 'password123' };
            User.findOne.mockResolvedValue(user);
            bcrypt.compare.mockResolvedValue(true);
            JwtService.generateToken.mockReturnValue('mock-token');

            await authController.login(mockReq, mockRes, next);

            expect(mockRes.json).toHaveBeenCalledWith({ token: 'mock-token' });
        });

        it('should return 401 on invalid credentials', async () => {
            mockReq.body = { email: 'test@test.com', password: 'wrongpassword' };
            User.findOne.mockResolvedValue(null);

            await authController.login(mockReq, mockRes, next);

            expect(mockRes.status).toHaveBeenCalledWith(HTTP_STATUS.UNAUTHORIZED);
        });
    });
});
