services:
  app:
    build: .
    ports:
      - "${PORT:-3000}:3000"
<%_ if (database !== 'None' || communication === 'Kafka') { -%>
    depends_on:
<%_ if (database !== 'None') { -%>
      - db
<%_ } -%>
<%_ if (communication === 'Kafka') { -%>
      - kafka
<%_ } -%>
<%_ } -%>
<%_ if (communication === 'Kafka') { -%>
    environment:
      - KAFKA_BROKER=kafka:9092
      - KAFKAJS_NO_PARTITIONER_WARNING=1
      - PORT=3000
<%_ if (caching === 'Redis') { -%>
      - REDIS_HOST=redis
      - REDIS_PORT=6379
      - REDIS_PASSWORD=
<%_ } -%>
<%_ if (database !== 'None') { -%>
      - DB_HOST=db
<%_ if (database === 'MySQL') { -%>
      - DB_USER=root
      - DB_PASSWORD=root
      - DB_NAME=<%= dbName %>
      - DB_PORT=3306
<%_ } -%><%_ if (database === 'PostgreSQL') { -%>
      - DB_USER=postgres
      - DB_PASSWORD=root
      - DB_NAME=<%= dbName %>
      - DB_PORT=5432
<%_ } -%><%_ if (database === 'MongoDB') { -%>
      - DB_NAME=<%= dbName %>
      - DB_PORT=27017
<%_ } -%>
<% if (auth.includes('JWT')) { -%>
      - JWT_SECRET=your_jwt_secret_key_here_change_it
      - JWT_EXPIRES_IN=1d
<% } -%>
<%_ } -%>
<%_ } else { -%>
    environment:
      - PORT=3000
<%_ if (caching === 'Redis') { -%>
      - REDIS_HOST=redis
      - REDIS_PORT=6379
      - REDIS_PASSWORD=
<%_ } -%>
<%_ if (database !== 'None') { -%>
      - DB_HOST=db
<%_ if (database === 'MySQL') { -%>
      - DB_USER=root
      - DB_PASSWORD=root
      - DB_NAME=<%= dbName %>
      - DB_PORT=3306
<%_ } -%><%_ if (database === 'PostgreSQL') { -%>
      - DB_USER=postgres
      - DB_PASSWORD=root
      - DB_NAME=<%= dbName %>
      - DB_PORT=5432
<%_ } -%><%_ if (database === 'MongoDB') { -%>
      - DB_NAME=<%= dbName %>
      - DB_PORT=27017
<%_ } -%>
<%_ } -%>
<%_ if (auth.includes('JWT')) { -%>
      - JWT_SECRET=your_jwt_secret_key_here_change_it
      - JWT_EXPIRES_IN=1d
<%_ } -%>
<%_ } -%>
<%_ if (database !== 'None') { -%>
  db:
<%_ if (database === 'MySQL') { -%>
    image: mysql:8.0
    restart: always
    environment:
      MYSQL_ROOT_PASSWORD: root
      MYSQL_DATABASE: <%= dbName %>
    ports:
      - "${DB_PORT:-3306}:3306"
    volumes:
      - ./flyway/sql:/docker-entrypoint-initdb.d
<%_ } else if (database === 'PostgreSQL') { -%>
    image: postgres:15
    restart: always
    environment:
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: root
      POSTGRES_DB: <%= dbName %>
    ports:
      - "${DB_PORT:-5432}:5432"
    volumes:
      - ./flyway/sql:/docker-entrypoint-initdb.d
<%_ } else if (database === 'MongoDB') { -%>
    image: mongo:latest
    restart: always
    environment:
      MONGO_INITDB_DATABASE: <%= dbName %>
    ports:
      - "${DB_PORT:-27017}:27017"
    volumes:
      - mongodb_data:/data/db

  mongo-migrate:
    image: node:22-slim
    working_dir: /app
    volumes:
      - .:/app
    command: sh -c "npm install migrate-mongo && npm run migrate"
    environment:
      - DB_HOST=db
      - DB_NAME=<%= dbName %>
    depends_on:
      - db
<%_ } -%>
<%_ } -%>
<%_ if (database !== 'MongoDB' && database !== 'None') { -%>
  flyway:
    image: flyway/flyway
    command: -connectRetries=60 migrate
    volumes:
      - ./flyway/sql:/flyway/sql
    environment:
<%_ if (database === 'MySQL') { -%>
      FLYWAY_URL: jdbc:mysql://db:3306/<%= dbName %>
      FLYWAY_USER: root
      FLYWAY_PASSWORD: root
      FLYWAY_BASELINE_ON_MIGRATE: "true"
<%_ } -%><%_ if (database === 'PostgreSQL') { -%>
      FLYWAY_URL: jdbc:postgresql://db:5432/<%= dbName %>
      FLYWAY_USER: postgres
      FLYWAY_PASSWORD: root
      FLYWAY_BASELINE_ON_MIGRATE: "true"
<%_ } -%>
    depends_on:
      - db
<%_ } -%>
<%_ if (communication === 'Kafka') { -%>
  kafka:
    image: bitnamilegacy/kafka:3.4.1-debian-12-r39
    ports:
      - "${KAFKA_EXTERNAL_PORT:-9093}:9093"
    environment:
      - KAFKA_ENABLE_KRAFT=yes
      - KAFKA_CFG_PROCESS_ROLES=broker,controller
      - KAFKA_CFG_CONTROLLER_QUORUM_VOTERS=1@localhost:9094
      - KAFKA_CFG_NODE_ID=1
      - KAFKA_CFG_ADVERTISED_LISTENERS=PLAINTEXT://kafka:9092,PLAINTEXT_HOST://localhost:${KAFKA_PORT:-9093}
      - KAFKA_CFG_LISTENERS=PLAINTEXT://:9092,PLAINTEXT_HOST://:9093,CONTROLLER://:9094
      - KAFKA_CFG_LISTENER_SECURITY_PROTOCOL_MAP=CONTROLLER:PLAINTEXT,PLAINTEXT:PLAINTEXT,PLAINTEXT_HOST:PLAINTEXT
      - KAFKA_CFG_CONTROLLER_LISTENER_NAMES=CONTROLLER
      - KAFKA_CFG_INTER_BROKER_LISTENER_NAME=PLAINTEXT
<%_ } -%>
<%_ if (caching === 'Redis') { -%>
  redis:
    image: redis:alpine
    restart: always
    ports:
      - "${REDIS_PORT:-6379}:6379"
<%_ } -%>
<%_ if (database !== 'None') { -%>
volumes:
  <%= database.toLowerCase() %>_data:
<%_ } -%>
