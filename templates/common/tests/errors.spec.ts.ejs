<%_ if (language === 'TypeScript') { _%>
import { ApiError } from '@/errors/ApiError';
import { BadRequestError } from '@/errors/BadRequestError';
import { NotFoundError } from '@/errors/NotFoundError';
import { HTTP_STATUS } from '@/utils/httpCodes';
<%_ } else { _%>
const { ApiError } = require('../src/errors/ApiError');
const { BadRequestError } = require('../src/errors/BadRequestError');
const { NotFoundError } = require('../src/errors/NotFoundError');
const { HTTP_STATUS } = require('../src/utils/httpCodes');
<%_ } _%>

describe('Error Classes', () => {
  it('ApiError should correctly inherit from Error and set properties', () => {
    const error = new ApiError(HTTP_STATUS.INTERNAL_SERVER_ERROR, 'Custom Error');
    expect(error).toBeInstanceOf(Error);
    expect(error.statusCode).toBe(HTTP_STATUS.INTERNAL_SERVER_ERROR);
    expect(error.message).toBe('Custom Error');
    expect(error.isOperational).toBe(true);
  });

  it('ApiError should use custom stack when provided', () => {
    const error = new ApiError(HTTP_STATUS.INTERNAL_SERVER_ERROR, 'msg', false, 'custom-stack');
    expect(error.stack).toBe('custom-stack');
    expect(error.isOperational).toBe(false);
  });

  it('BadRequestError should have 400 statusCode', () => {
    const error = new BadRequestError('Bad input');
    expect(error.statusCode).toBe(HTTP_STATUS.BAD_REQUEST);
    expect(error.message).toBe('Bad input');
  });

  it('BadRequestError should use default message', () => {
    const error = new BadRequestError();
    expect(error.statusCode).toBe(HTTP_STATUS.BAD_REQUEST);
    expect(error.message).toBe('Bad request');
  });

  it('NotFoundError should have 404 statusCode', () => {
    const error = new NotFoundError('Resource missing');
    expect(error.statusCode).toBe(HTTP_STATUS.NOT_FOUND);
    expect(error.message).toBe('Resource missing');
  });

  it('NotFoundError should use default message', () => {
    const error = new NotFoundError();
    expect(error.statusCode).toBe(HTTP_STATUS.NOT_FOUND);
    expect(error.message).toBe('Resource not found');
  });
});
