import mongoose, { Schema, Document } from 'mongoose';

export interface IUser extends Document {
    name: string;
    email: string;
    <% if (auth.includes('JWT')) { %>password?: string | null;<% } %>
    <% if (socialAuth && socialAuth.includes('Google')) { %>googleId?: string | null;<% } %>
    <% if (socialAuth && socialAuth.includes('GitHub')) { %>githubId?: string | null;<% } %>
    createdAt: Date;
    deletedAt?: Date | null;
}

const UserSchema: Schema = new Schema({
    name: {
        type: String,
        required: true
    },
    email: {
        type: String,
        required: true,
        unique: true
    },
    <% if (auth.includes('JWT')) { %>
    password: {
        type: String,
        required: false
    },
    <% } %>
    <% if (socialAuth && socialAuth.includes('Google')) { %>
    googleId: {
        type: String,
        unique: true,
        sparse: true
    },
    <% } %>
    <% if (socialAuth && socialAuth.includes('GitHub')) { %>
    githubId: {
        type: String,
        unique: true,
        sparse: true
    },
    <% } %>
    createdAt: {
        type: Date,
        default: Date.now
    },
    deletedAt: {
        type: Date,
        default: null
    }
});


export default mongoose.model<IUser>('User', UserSchema);
