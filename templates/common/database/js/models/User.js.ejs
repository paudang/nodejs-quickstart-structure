<% if (database === 'None') { -%>
class UserModel {
  static mockData = [];

  static async find() {
    return this.mockData;
  }

  static async findOne(query) {
    return this.mockData.find((u) => {
      return Object.entries(query).every(([key, value]) => u[key] === value);
    });
  }

  static async findAll() {
    return this.mockData;
  }

  static async create(data) {
    const { id, ...rest } = data;
    const newUser = { id: String(this.mockData.length + 1), ...rest };
    this.mockData.push(newUser);
    return newUser;
  }

  static async findByPk(id) {
    return this.mockData.find((u) => u.id === String(id));
  }

  static async update(id, data) {
    const user = await this.findByPk(id);
    if (user) {
      Object.assign(user, data);
    }
    return user;
  }

  static async destroy(id) {
    const index = this.mockData.findIndex((u) => u.id === String(id));
    if (index !== -1) {
      this.mockData.splice(index, 1);
      return true;
    }
    return false;
  }
}

module.exports = UserModel;
<% } else { -%>
const { DataTypes, Model } = require('sequelize');
<% if (architecture === 'MVC') { %>const sequelize = require('../config/database');<% } else { %>const sequelize = require('../database');<% } %>

class User extends Model {}

User.init(
  {
    id: {
      type: DataTypes.INTEGER,
      autoIncrement: true,
      primaryKey: true,
    },
    name: {
      type: DataTypes.STRING,
      allowNull: false,
    },
    email: {
      type: DataTypes.STRING,
      allowNull: false,
      unique: true,
    },
    <% if (auth.includes('JWT')) { %>
    password: {
      type: DataTypes.STRING,
      allowNull: false,
    },
    <% } %>
    deletedAt: {
      type: DataTypes.DATE,
      allowNull: true,
    },
  },
  {
    sequelize,
    tableName: 'users',
    underscored: true,
    paranoid: true,
  }
);


module.exports = User;
<% } -%>
