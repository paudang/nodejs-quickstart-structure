    "url": "git+https://github.com/paudang/nodejs-quickstart-structure.git"
  },
  "bugs": {
    "url": "https://github.com/paudang/nodejs-quickstart-structure/issues"
  },
  "homepage": "https://github.com/paudang/nodejs-quickstart-structure#readme",
  "license": "ISC",
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^14.0.3",
    "ejs": "^5.0.1",
    "fs-extra": "^11.3.0",
    "inquirer": "^13.3.2"
  },
