    "test:e2e:windows": "node scripts/validate-windows.js",
    "test:e2e:linux": "node scripts/validate-linux.js",
    "test:verify:mongo": "node scripts/verify-migration.js"
  },
  "keywords": [
    "nodejs",
    "node",
    "quickstart",
    "structure",
    "cli",
